# ==================== API CONFIGURATION ====================
NEXT_PUBLIC_API_URL=http://192.168.18.60:7000
NEXT_PUBLIC_WS_URL=ws://192.168.18.60:3002/ws/dashboard

# ==================== APP INFO ====================
NEXT_PUBLIC_APP_NAME="Printer Monitoring Dashboard"
NEXT_PUBLIC_APP_VERSION="1.0.0"
NEXT_PUBLIC_COMPANY_NAME="Newton"

# ==================== UI SETTINGS ====================
NEXT_PUBLIC_REFRESH_INTERVAL=5000
NEXT_PUBLIC_LOW_INK_THRESHOLD=15
NEXT_PUBLIC_CRITICAL_INK_THRESHOLD=10
NEXT_PUBLIC_AUTO_REFRESH=true

# ==================== FEATURE FLAGS ====================
NEXT_PUBLIC_ENABLE_WEBSOCKET=true
NEXT_PUBLIC_ENABLE_REPORTS=true
NEXT_PUBLIC_ENABLE_PRINTER_CONTROL=true
NEXT_PUBLIC_ENABLE_INK_MONITORING=true

# ==================== DEFAULT VALUES ====================
NEXT_PUBLIC_DEFAULT_DATE_RANGE=7
NEXT_PUBLIC_MAX_AGENTS_DISPLAY=10
NEXT_PUBLIC_TIMEZONE="Asia/Jakarta"

# ==================== DEBUG & DEVELOPMENT ====================
NEXT_PUBLIC_DEBUG_MODE=false
NEXT_PUBLIC_LOG_LEVEL="info"
NEXT_PUBLIC_API_TIMEOUT=10000
NEXT_PUBLIC_WS_RECONNECT_DELAY=5000

# ==================== MOCK DATA (Development only) ====================
NEXT_PUBLIC_USE_MOCK_DATA=false
NEXT_PUBLIC_MOCK_AGENT_ID="WINDOWS-PC-001"